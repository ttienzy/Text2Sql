# =============================================================================
# TextToSqlAgent Console Application - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# =============================================================================
# OpenAI Configuration
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_SQL_GENERATION_MODEL=gpt-4o
OPENAI_REFLECTION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=8192
OPENAI_TEMPERATURE=0.3
OPENAI_TOP_P=0.95
OPENAI_FREQUENCY_PENALTY=0.0
OPENAI_PRESENCE_PENALTY=0.0
OPENAI_REQUEST_TIMEOUT=120
OPENAI_MAX_RETRIES=3

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_CONNECTION_STRING=Server=localhost;Database=YourDatabase;User Id=YourUser;Password=YourPassword;TrustServerCertificate=true;
DATABASE_COMMAND_TIMEOUT=60
DATABASE_MAX_RETRY_ATTEMPTS=3

# Alternative database examples:
# PostgreSQL: Host=localhost;Database=YourDatabase;Username=YourUser;Password=YourPassword;
# MySQL: Server=localhost;Database=YourDatabase;Uid=YourUser;Pwd=YourPassword;
# SQLite: Data Source=YourDatabase.db;

# =============================================================================
# Qdrant Vector Database Configuration
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=schema_embeddings_large
QDRANT_VECTOR_SIZE=3072
QDRANT_API_KEY=your-qdrant-api-key-if-needed
QDRANT_SEARCH_LIMIT=10
QDRANT_SCORE_THRESHOLD=0.75

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_MAX_ITERATIONS=12
AGENT_MAX_STEPS=12
AGENT_ENABLE_REFLECTION=true
AGENT_ENABLE_SELF_CORRECTION=true
AGENT_MAX_SELF_CORRECTION_ATTEMPTS=3
AGENT_REASONING_DEPTH=deep
AGENT_MIN_CONFIDENCE_SCORE=0.8
AGENT_TOOL_TIMEOUT=30
AGENT_MAX_CONTEXT_LENGTH=16000

# =============================================================================
# RAG (Retrieval Augmented Generation) Configuration
# =============================================================================
RAG_TOP_K=8
RAG_MIN_SCORE=0.75
RAG_ENABLE_HYBRID_SEARCH=true
RAG_RETRIEVAL_STRATEGY=hybrid_mmr
RAG_MMR_DIVERSITY_SCORE=0.3
RAG_FUZZY_MATCH_THRESHOLD=0.85
RAG_MAX_CONTEXT_TABLES=10

# =============================================================================
# Caching Configuration
# =============================================================================
CACHE_DEFAULT_TTL_MINUTES=120
CACHE_SCHEMA_TTL_MINUTES=2880
CACHE_QUERY_RESULT_TTL_MINUTES=60
CACHE_EMBEDDING_TTL_MINUTES=1440
CACHE_MAX_SIZE=1GB

# =============================================================================
# Production Settings
# =============================================================================
PRODUCTION_ENABLE_CACHING=true
PRODUCTION_CACHE_TTL_MINUTES=120
PRODUCTION_ENABLE_RATE_LIMITING=false
PRODUCTION_RATE_LIMIT_MAX_REQUESTS=200
PRODUCTION_RATE_LIMIT_WINDOW_MINUTES=1
PRODUCTION_MAX_COMPLEXITY_SCORE=30.0
PRODUCTION_MAX_QUERY_EXECUTION_TIME=60

# =============================================================================
# Observability & Monitoring
# =============================================================================
OBSERVABILITY_ENABLE_METRICS=true
OBSERVABILITY_ENABLE_TELEMETRY=true
OBSERVABILITY_ENABLE_HEALTH_CHECKS=true
OBSERVABILITY_METRICS_RETENTION_DAYS=7
OBSERVABILITY_SAMPLE_RATE=1.0
OBSERVABILITY_TRACING_EXPORTER=console

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=Information
LOG_ENABLE_DETAILED_LOGGING=true
LOG_ENABLE_PERFORMANCE_TRACKING=true
LOG_ENABLE_ERROR_TRACKING=true

# =============================================================================
# Development Settings (Optional)
# =============================================================================
# Uncomment for development mode
# ASPNETCORE_ENVIRONMENT=Development
# DOTNET_ENVIRONMENT=Development