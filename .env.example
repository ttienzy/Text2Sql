# Copy this file to .env before running docker compose.

# SQL Server container password.
# SQL Server requires a strong password: uppercase, lowercase, number, symbol, 8+ chars.
SA_PASSWORD=YourStrong@Passw0rd
APP_DB_NAME=TextToSqlAgentDB

# AI provider. Keep OpenAI unless you explicitly switch to Gemini.
LLM_PROVIDER=OpenAI
OPENAI_API_KEY=
GEMINI_API_KEY=

# Security keys for self-hosting. Replace these before exposing the app publicly.
JWT_SECRET=change-this-jwt-secret-at-least-32-characters
JWT_ISSUER=TextToSqlAgentAPI
JWT_AUDIENCE=TextToSqlAgentClient
ENCRYPTION_KEY=change-this-encryption-key-32-chars

# Vector collection must match the embedding model dimension.
# text-embedding-3-large = 3072, text-embedding-3-small = 1536.
QDRANT_COLLECTION_NAME=schema_embeddings_large
QDRANT_VECTOR_SIZE=3072

# The Docker frontend is built with a browser-visible API URL.
VITE_API_BASE_URL=http://localhost:5251

# Development bootstrap data creates the default dev user used by local demos.
SEED_DEVELOPMENT_DATA=true

# Optional sidecar tuning.
INTENT_CLASSIFIER_PROVIDER=Python
PYTHON_SIDECAR_TIMEOUT_MS=500
