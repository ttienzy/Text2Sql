# TextToSqlAgent Environment Variables Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# ============================================
# Required: AI API Keys
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# Required: Security
# ============================================
# Generate a secure key: https://generate-random.org/secret-key-generator
JWT_SECRET=your-secure-jwt-secret-key-min-32-characters

# ============================================
# Optional: Database Connection
# ============================================
# If not set, will use appsettings.json
# CONNECTION__DefaultConnection=Server=.;Database=TextToSqlAgent;User Id=sa;Password=123;TrustServerCertificate=True;

# ============================================
# Optional: Vector Database
# ============================================
QDRANT_API_KEY=your-qdrant-api-key-here

# ============================================
# How to set environment variables:
# ============================================
# Windows (PowerShell): $env:OPENAI_API_KEY="sk-..."
# Windows (CMD): set OPENAI_API_KEY=sk-...
# Linux/Mac: export OPENAI_API_KEY="sk-..."
#
# Or use .env file with dotnet-env package:
# https://github.com/tonerdo/dotnet-env

# ============================================
# API runs on port 5252 by default
# Frontend .env: VITE_API_BASE_URL=http://localhost:5252
