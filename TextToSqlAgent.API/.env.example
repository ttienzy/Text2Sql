# Local API-only development example.
# For Docker self-hosting, use the repository-level .env.example instead.

JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_ISSUER=TextToSqlAgentAPI
JWT_AUDIENCE=TextToSqlAgentClient

LLM_PROVIDER=OpenAI
OPENAI_API_KEY=your-openai-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

ConnectionStrings__DefaultConnection=Server=localhost,11433;Database=TextToSqlAgentDB;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;Encrypt=False;
DATABASE_CONNECTION_STRING=Server=localhost,11433;Database=TextToSqlAgentDB;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;Encrypt=False;

QDRANT_URL=http://localhost:6333
Qdrant__CollectionName=schema_embeddings_large
Qdrant__VectorSize=3072
QDRANT_API_KEY=

REDIS_CONNECTION=127.0.0.1:6379

ENCRYPTION_KEY=your-32-character-encryption-key-here

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_NAME=TextToSQL Agent
SMTP_SENDER_EMAIL=your-email@gmail.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
