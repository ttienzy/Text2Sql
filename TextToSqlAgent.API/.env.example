# =============================================================================
# TextToSqlAgent API - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# =============================================================================
# REQUIRED: Security Configuration
# =============================================================================
# JWT Secret Key (minimum 32 characters for security)
# Generate secure key: https://generate-random.org/secret-key-generator
JWT_SECRET=your-secure-jwt-secret-key-minimum-32-characters-long

# Encryption Key for database password encryption (minimum 32 characters)
ENCRYPTION_KEY=your-secure-encryption-key-minimum-32-characters-long

# =============================================================================
# REQUIRED: AI API Keys (at least one provider)
# =============================================================================
# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini Configuration (alternative to OpenAI)
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# OPTIONAL: Database Configuration
# =============================================================================
# Primary database connection (if not set, uses SQLite from appsettings.json)
DATABASE_CONNECTION_STRING=Server=.;Database=TextToSqlAgent;User Id=sa;Password=123;TrustServerCertificate=True;

# Alternative format for ASP.NET Core configuration
# CONNECTION__DefaultConnection=Server=localhost;Database=TextToSqlAgent;User Id=sa;Password=YourPassword;TrustServerCertificate=True;

# Database provider (sqlserver, postgresql, mysql, sqlite)
DATABASE_PROVIDER=sqlserver

# =============================================================================
# OPTIONAL: Vector Database Configuration
# =============================================================================
# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION_NAME=schema_embeddings

# =============================================================================
# OPTIONAL: Environment-Specific Overrides
# =============================================================================
# ASP.NET Core Environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Logging Level Override
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__TEXTTOSQLAGENT=Debug

# =============================================================================
# OPTIONAL: Production Settings
# =============================================================================
# Rate Limiting
PRODUCTION__ENABLERATELIMITING=true
PRODUCTION__RATELIMITMAXREQUESTS=100
PRODUCTION__RATELIMITWINDOWMINUTES=1

# Caching
PRODUCTION__ENABLECACHING=true
PRODUCTION__CACHETTLMINUTES=60

# Security
PRODUCTION__ENABLESQLINJECTIONPREVENTION=true
PRODUCTION__MAXCOMPLEXITYSCORE=30.0

# =============================================================================
# OPTIONAL: Agent Configuration
# =============================================================================
AGENT__MAXITERATIONS=12
AGENT__ENABLEREFLECTION=true
AGENT__ENABLESELFCORRECTION=true
AGENT__REASONINGDEPTH=deep

# =============================================================================
# OPTIONAL: Observability Configuration
# =============================================================================
OBSERVABILITY__ENABLEMETRICS=true
OBSERVABILITY__ENABLETELEMETRY=true
OBSERVABILITY__ENABLEHEALTHCHECKS=true
OBSERVABILITY__ENABLEDETAILEDLOGGING=true

# =============================================================================
# How to Use Environment Variables
# =============================================================================
# 
# Method 1: Set in your shell session
# Windows PowerShell:
#   $env:OPENAI_API_KEY="sk-your-key-here"
#   $env:JWT_SECRET="your-jwt-secret-here"
#
# Windows Command Prompt:
#   set OPENAI_API_KEY=sk-your-key-here
#   set JWT_SECRET=your-jwt-secret-here
#
# Linux/Mac:
#   export OPENAI_API_KEY="sk-your-key-here"
#   export JWT_SECRET="your-jwt-secret-here"
#
# Method 2: Use .env file (recommended for development)
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. The application will automatically load them
#
# Method 3: Use system environment variables
# Set them in your operating system's environment variables
#
# =============================================================================
# Configuration Priority (highest to lowest)
# =============================================================================
# 1. Environment Variables (highest priority)
# 2. .env file
# 3. appsettings.{Environment}.json
# 4. appsettings.json (lowest priority)
#
# =============================================================================
# Security Notes
# =============================================================================
# - Never commit .env file to version control
# - Use strong, unique keys for JWT_SECRET and ENCRYPTION_KEY
# - In production, use your platform's secret management (Azure Key Vault, AWS Secrets Manager, etc.)
# - Rotate keys regularly in production environments
#
# =============================================================================
# Default Ports
# =============================================================================
# API: http://localhost:5000 or https://localhost:5001
# Health Check: http://localhost:5000/api/health
# Swagger UI: http://localhost:5000/swagger (Development only)
