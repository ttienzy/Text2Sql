{
  "question": "What tables are available in the database?"
}

### 6. Test Query - Complex
POST {{baseUrl}}/api/test/test-query
Content-Type: application/json

{
  "question": "Show me top 10 customers by revenue"
}

### 7. Clear Qdrant Collection (Fix Dimension Mismatch)
POST {{baseUrl}}/api/test/clear-qdrant
Content-Type: application/json

# This API will:
# - Clear the existing Qdrant collection
# - Allow re-creation with correct dimensions (3072 for text-embedding-3-large)
# - Fix the vector dimension mismatch issue

###############################################################################
# INSTRUCTIONS
###############################################################################

# HOW TO USE:
# 
# 1. Make sure your API is running: dotnet run --project TextToSqlAgent.API
# 
# 2. Make sure you have SQL Server running with:
#    - Server: . (local instance)
#    - Database: TextToSqlTest
#    - Username: sa
#    - Password: 123
#    - TrustServerCertificate: True
#
# 3. Run Test API 1 first to index schema to Qdrant:
#    - This will test database connection
#    - Scan all tables and columns
#    - Index schema information to Qdrant vector database
#
# 4. Then run Test API 2 with different questions:
#    - This will test schema retrieval from Qdrant
#    - Show available tables in database
#    - Provide query recommendations
#
# EXPECTED RESULTS:
#
# Test API 1 (Schema Indexing):
# {
#   "success": true,
#   "step": "completed",
#   "tablesFound": 5,
#   "tablesIndexed": 5,
#   "collectionName": "schema_embeddings_test-user-123",
#   "qdrantStatus": "Indexed successfully"
# }
#
# Test API 2a (Basic Query Test):
# {
#   "success": true,
#   "question": "Show me all customers",
#   "databaseConnection": true,
#   "tablesInDatabase": ["Customers", "Orders", "Products"],
#   "tablesCount": 3,
#   "qdrantSchemaRetrieval": {
#     "success": true,
#     "schemasFound": 2,
#     "collectionExists": true
#   },
#   "recommendation": "Try querying customer-related tables"
# }
#
# Test API 2b (Complete Query Processing - Like Console Project):
# {
#   "success": true,
#   "question": "Show me all customers",
#   "answer": "Here are all the customers from the database:\n\n[Customer data with intelligent formatting]",
#   "sqlGenerated": "SELECT CustomerID, CompanyName, ContactName FROM Customers ORDER BY CompanyName",
#   "queryResult": {
#     "success": true,
