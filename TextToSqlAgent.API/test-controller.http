#       {"CustomerID": "ALFKI", "CompanyName": "Alfreds Futterkiste", "ContactName": "Maria Anders"},
#       {"CustomerID": "ANATR", "CompanyName": "Ana Trujillo Emparedados", "ContactName": "Ana Trujillo"}
#     ],
#     "rowCount": 91,
#     "executionTimeMs": 45
#   },
#   "processingSteps": [
#     "Step 0: Validate query relevance",
#     "Step 1: Load database schema",
#     "Step 2: Normalize with conversation context",
#     "Step 4: RAG - Retrieve relevant schema",
#     "Step 5: Analyze intent",
#     "Step 6: Generate SQL with RAG context",
#     "Step 7: Validate SQL safety",
#     "Step 9: Execute SQL with self-correction",
#     "Step 10: Format intelligent answer"
#   ],
#   "queryExplanation": "This query retrieves all customer records...",
#   "suggestedQueries": [
#     "Show me customers from a specific city",
#     "Find customers with recent orders",
#     "List top customers by order count"
#   ],
#   "wasCorrected": false,
#   "correctionAttempts": 0
# }
#
# TROUBLESHOOTING:
#
# If you get database connection errors:
# - Make sure SQL Server is running
# - Check if TextToSqlTest database exists
# - Verify sa user has correct password (123)
# - Ensure SQL Server allows SQL authentication
#
# If you get Qdrant errors:
# - Make sure Qdrant is running (usually on port 6333)
# - Check Qdrant configuration in appsettings.json
# - Verify network connectivity to Qdrant instance
#
# These APIs are PUBLIC (no authentication required) for testing purposes only!
# Remove or secure them before production deployment.