{
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "TextToSqlAgent": "Information"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=identity.db"
    },
    "AllowedHosts": "*",
    "Database": {
        "Provider": "SqlServer",
        "ConnectionString": "",
        "CommandTimeout": 60,
        "MaxRetryAttempts": 3
    },
    "LLMProvider": "OpenAI",
    "OpenAI": {
        "ApiKey": "",
        "Model": "gpt-4o-mini",
        "MaxTokens": 4096,
        "Temperature": 0.7,
        "BaseUrl": "https://api.openai.com/v1"
    },
    "Gemini": {
        "ApiKey": "",
        "Model": "gemini-2.0-flash-exp",
        "MaxTokens": 8192,
        "Temperature": 0.7
    },
    "Qdrant": {
        "Url": "",
        "CollectionName": "schema_embeddings",
        "VectorSize": 768,
        "ApiKey": ""
    },
    "Agent": {
        "UseLegacyMode": false,
        "EnableDevQueryEndpoint": false,
        "MaxIterations": 8,
        "MaxSteps": 8,
        "EnableReflection": true,
        "EnableSelfCorrection": true,
        "MaxSelfCorrectionAttempts": 2
    },
    "RAG": {
        "TopK": 5,
        "MinScore": 0.75,
        "EnableHybridSearch": true,
        "EnableAdvancedSchemaLinking": true,
        "EnableEntityRecognition": true,
        "EnableRelationshipInference": true
    },
    "Production": {
        "EnableCaching": true,
        "CacheTTLMinutes": 60,
        "EnableRateLimiting": true,
        "RateLimitMaxRequests": 100,
        "RateLimitWindowMinutes": 1,
        "EnableSqlInjectionPrevention": true,
        "MaxComplexityScore": 20.0
    },
    "Cache": {
        "DefaultTTLMinutes": 60,
        "SchemaCacheTTLMinutes": 1440,
        "QueryResultCacheTTLMinutes": 30,
        "EmbeddingCacheTTLMinutes": 720
    },
    "Redis": {
        "ConnectionString": "",
        "InstanceName": "TextToSqlAgent:",
        "Enabled": true
    },
    "Jwt": {
        "Key": "",
        "Issuer": "TextToSqlAgentAPI",
        "Audience": "TextToSqlAgentClient",
        "ExpiryMinutes": 30
    },
    "Observability": {
        "EnableMetrics": true,
        "EnableTelemetry": true,
        "EnableHealthChecks": true,
        "MetricsRetentionDays": 30
    },
    "Prompts": {
        "EnableVersioning": true,
        "EnableABTesting": true,
        "DefaultVersion": "v1"
    }
}
