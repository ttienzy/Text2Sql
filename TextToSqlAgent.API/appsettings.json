{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "TextToSqlAgent.API"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=TextToSqlAgentDB;User Id=sa;Password=123;TrustServerCertificate=True;"
  },
  "LLMProvider": "OpenAI",
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o",
    "ReasoningModel": "gpt-4o",
    "SqlGenerationModel": "gpt-4o",
    "ReflectionModel": "gpt-4o-mini",
    "EmbeddingModel": "text-embedding-3-large",
    "MaxTokens": 8192,
    "Temperature": 0.3,
    "TopP": 0.95,
    "FrequencyPenalty": 0.0,
    "PresencePenalty": 0.0,
    "RequestTimeout": 120,
    "MaxRetries": 3,
    "EnableCaching": true,
    "CacheEmbeddings": true
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-1.5-pro",
    "EmbeddingModel": "text-embedding-004",
    "MaxTokens": 8192,
    "Temperature": 0.3,
    "RequestTimeout": 120,
    "MaxRetries": 3
  },
  "Database": {
    "ConnectionString": "",
    "Provider": "sqlserver",
    "CommandTimeout": 60,
    "MaxRetryAttempts": 3
  },
  "Qdrant": {
    "Url": "http://localhost:6333",
    "CollectionName": "schema_embeddings_large",
    "VectorSize": 3072,
    "ApiKey": "",
    "SearchLimit": 10,
    "ScoreThreshold": 0.75,
    "EnableHNSW": true,
    "HNSWEfConstruct": 200,
    "HNSWM": 16
  },
  "Agent": {
    "UseLegacyMode": false,
    "MaxIterations": 12,
    "MaxSteps": 12,
    "EnableReflection": true,
    "EnableSelfCorrection": true,
    "MaxSelfCorrectionAttempts": 3,
    "ReasoningDepth": "deep",
    "EnableChainOfThought": true,
    "EnableStepByStepReasoning": true,
    "MinConfidenceScore": 0.8,
    "ToolSelectionStrategy": "intelligent",
    "EnableParallelToolExecution": false,
    "ToolTimeout": 30,
    "EnableWorkingMemory": true,
    "MaxContextLength": 16000,
    "EnableContextCompression": true,
    "EnableSQLExplanation": true,
    "EnableDetailedLogging": true,
    "EnableDevQueryEndpoint": false
  },
  "RAG": {
    "TopK": 8,
    "MinScore": 0.75,
    "EnableHybridSearch": true,
    "EnableAdvancedSchemaLinking": true,
    "EnableEntityRecognition": true,
    "EnableRelationshipInference": true,
    "RetrievalStrategy": "hybrid_mmr",
    "MMRDiversityScore": 0.3,
    "EnableReranking": true,
    "RerankingModel": "cross-encoder",
    "SchemaLinkingAlgorithm": "advanced",
    "EnableFuzzyMatching": true,
    "FuzzyMatchThreshold": 0.85,
    "EnableSemanticSimilarity": true,
    "EnableQueryExpansion": true,
    "EnableSynonymDetection": true,
    "EnableAbbreviationExpansion": true,
    "MaxContextTables": 10
  },
  "Production": {
    "EnableCaching": true,
    "CacheTTLMinutes": 120,
    "EnableRateLimiting": true,
    "RateLimitMaxRequests": 100,
    "RateLimitWindowMinutes": 1,
    "EnableSqlInjectionPrevention": true,
    "MaxComplexityScore": 30.0,
    "EnableQueryOptimization": true,
    "MaxQueryExecutionTime": 60,
    "EnableQueryPlanAnalysis": true,
    "EnableResultVerification": true,
    "VerificationStrategy": "comprehensive",
    "EnableAnomalyDetection": true
  },
  "Cache": {
    "DefaultTTLMinutes": 120,
    "SchemaCacheTTLMinutes": 2880,
    "QueryResultCacheTTLMinutes": 60,
    "EmbeddingCacheTTLMinutes": 1440,
    "EnableIntelligentCaching": true,
    "CacheWarmupOnStartup": false,
    "EnablePredictiveCaching": false,
    "MaxCacheSize": "1GB",
    "EnableSmartInvalidation": true,
    "InvalidationStrategy": "dependency-based"
  },
  "Observability": {
    "EnableMetrics": true,
    "EnableTelemetry": true,
    "EnableHealthChecks": true,
    "MetricsRetentionDays": 7,
    "EnableDetailedLogging": true,
    "EnablePerformanceTracking": true,
    "EnableErrorTracking": true,
    "SampleRate": 1.0,
    "EnableDistributedTracing": false,
    "TracingExporter": "console",
    "EnableSpanAttributes": true
  },
  "Conversation": {
    "MaxHistoryMessages": 20,
    "ConversationMemoryTTLHours": 24,
    "EnableFollowUpDetection": true,
    "MaxConversationTurns": 50,
    "EnableConversationAnalytics": true,
    "EnableConversationContext": true,
    "FollowUpSimilarityThreshold": 0.7,
    "EnableMemoryPersistence": true,
    "MaxMemorySizeMB": 100
  },
  "Jwt": {
    "Key": "TextToSqlAgentDevKey2024Secure!ThisIsLongEnough32+",
    "Issuer": "TextToSqlAgentAPI",
    "Audience": "TextToSqlAgentClient",
    "AccessTokenExpiryMinutes": 180,
    "RefreshTokenExpiryDays": 7
  },
  "Encryption": {
    "Key": "DefaultEncryptionKey32CharactersLong!"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "http://localhost:5173",
      "http://localhost:3000",
      "https://localhost:3001"
    ]
  },
  "AllowedHosts": "*"
}