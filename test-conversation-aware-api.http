### Test Conversation-Aware Agent v2 API

# First, login to get a token
POST http://localhost:5251/api/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "Admin123!"
}

### 
# Use the token from the login response in the Authorization header below
# Replace YOUR_JWT_TOKEN with the actual token

# Test v2 conversation-aware agent endpoint
POST http://localhost:5251/api/v2/agent/process
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "connectionId": "test-connection-id",
  "question": "Show me all users in the database",
  "conversationId": null,
  "includeFullHistory": true,
  "maxHistoryMessages": 20
}

###
# Test follow-up question with conversation context
POST http://localhost:5251/api/v2/agent/process
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "connectionId": "test-connection-id", 
  "question": "How many users are there in total?",
  "conversationId": "CONVERSATION_ID_FROM_PREVIOUS_RESPONSE",
  "includeFullHistory": true,
  "maxHistoryMessages": 20
}

###
# Get conversation context
GET http://localhost:5251/api/v2/agent/conversation/CONVERSATION_ID_FROM_PREVIOUS_RESPONSE/context
Authorization: Bearer YOUR_JWT_TOKEN

###
# Test health endpoint
GET http://localhost:5251/health