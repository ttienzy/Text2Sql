# TextToSQL Agent - Production Environment Variables
# Copy this file to .env and update with your production values

# API Base URL - Your production API endpoint
VITE_API_BASE_URL=https://api.yourdomain.com

# App Name
VITE_APP_NAME=TextToSQL Agent

# Token Refresh Buffer (milliseconds)
# How long before token expiry to trigger silent refresh
VITE_TOKEN_REFRESH_BUFFER_MS=60000
